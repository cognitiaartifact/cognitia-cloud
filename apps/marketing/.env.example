# Inlet Move marketing site (Astro) — public env vars (PUBLIC_ prefix is exposed to client)

# The URL the quote form POSTs to. In v1, this is the Hostinger PHP shim.
# In v1.1, swap to https://quote.inletmove.ca/api/quote (Vercel/Next).
# That swap is a one-env-var change — the form code stays identical.
PUBLIC_QUOTE_ENDPOINT=/quote-handler.php

# Live booking feed URL. v1: empty (component falls back to seed data).
# v1.1: https://quote.inletmove.ca/api/feed
PUBLIC_FEED_URL=

# Site URL (must match astro.config.mjs site:)
PUBLIC_SITE_URL=https://inletmove.ca

# Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX)
# Leave empty to disable tracking. Set in Hostinger hPanel or .env.local.
PUBLIC_GA4_ID=

# Google Search Console verification meta tag content
# Get from https://search.google.com/search-console → Add property → HTML tag
PUBLIC_GSC_VERIFICATION=
