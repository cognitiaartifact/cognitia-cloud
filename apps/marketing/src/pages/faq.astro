---
import Base from '../layouts/Base.astro';
import Nav from '../components/nav/Nav.astro';
import Footer from '../components/footer/Footer.astro';

const title = 'Frequently Asked Questions — Inlet Move Co. | Vancouver Movers';
const description =
  'Answers to common questions about hiring local movers in Metro Vancouver. Pricing, service area, what to expect, and how to get a quote from Inlet Move Co.';

type FAQ = { question: string; answer: string };

const faqs: FAQ[] = [
  {
    question: 'How much do movers cost in Vancouver?',
    answer:
      'Inlet Move Co. charges $150 per hour for a two-mover crew with a cargo van, with a $300 minimum (2 hours). There is no fuel surcharge, no stair fee, and no weekend upcharge. Most studio and 1-bedroom moves in Metro Vancouver take 2–4 hours. We text you a precise quote within an hour of your request.',
  },
  {
    question: 'What areas do you serve?',
    answer:
      'We serve all of Metro Vancouver: Vancouver, Burnaby, Richmond, Surrey, North Vancouver, West Vancouver, Coquitlam, and New Westminster. We also cover surrounding cities in the Lower Mainland. Check our service area page for neighborhood-specific info.',
  },
  {
    question: 'How quickly can I book a move?',
    answer:
      'We offer same-week availability for most moves. Submit a quote request and a real human will text you a precise quote within the hour. Many moves can be booked for the same week or even a few days out, depending on availability.',
  },
  {
    question: 'Do you charge extra for stairs, weekends, or fuel?',
    answer:
      'No. Our $150/hr rate is all-inclusive. There is no stair fee, no elevator fee, no weekend surcharge, and no fuel surcharge. The quote we give you is what you pay — our target overage from quote to final bill is under 5% (industry typical is around 22%).',
  },
  {
    question: 'Are your movers insured?',
    answer:
      'Yes. Every move includes $2 million in cargo and liability coverage. We are WorkSafeBC compliant with an active clearance letter, and we are a BC-registered moving company. Insurance certificate details will be published on our trust badges section once verification is complete.',
  },
  {
    question: 'What types of moves do you handle?',
    answer:
      'We handle studios, 1-bedroom through 3-bedroom apartments and houses, multigenerational household moves, senior downsizing moves, and single-item or partial moves. We have special training for handling religious, ceremonial, and culturally significant items with care.',
  },
  {
    question: 'How do I get a quote?',
    answer:
      'Visit our quote page and answer six quick questions — no login, no site visit required. A real human on our team will text you a precise quote within the hour. You can also call us or email hello@inletmove.ca.',
  },
  {
    question: 'Do you speak languages other than English?',
    answer:
      'Our team currently operates in English. Mandarin/Cantonese (中文), Punjabi (ਪੰਜਾਬੀ), and Hindi (हिंदी) language support are coming soon. We are a diverse, multicultural team and we are committed to serving Metro Vancouver\'s multilingual communities.',
  },
  {
    question: 'What should I do to prepare for my move?',
    answer:
      'Pack fragile items carefully, label boxes by room, and make sure pathways are clear. Let us know about any stairs, elevator access, parking restrictions, pets, or special items (pianos, artwork, ceremonial items) in your quote notes — it helps us plan and bring the right equipment.',
  },
  {
    question: 'What happens if something is damaged during the move?',
    answer:
      'We photograph fragile items, before-and-after conditions, and load-out on every job. If anything is ever questioned, there is proof. Our $2M cargo and liability coverage protects your belongings. Contact us immediately if you notice any damage and we will work with you to resolve it.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: f.answer,
    },
  })),
};
---

<Base title={title} description={description} extraSchema={[faqSchema]}>
  <Nav slot="nav" />

  <article class="bg-paper px-6 pb-24 pt-32 md:px-8">
    <div class="mx-auto max-w-3xl">
      <p class="mb-3 font-mono text-xs uppercase tracking-widest text-pacific">FAQ</p>
      <h1
        class="mb-4 font-display text-display-2 font-medium leading-tight tracking-tight text-inlet-navy display-soft"
      >
        Questions people actually
        <em class="display-italic text-ember">ask.</em>
      </h1>
      <p class="mb-12 font-body text-lg leading-relaxed text-graphite">
        Everything you need to know about hiring local movers in Metro Vancouver.
        Can't find your answer? <a href="/quote" class="text-pacific underline-offset-4 hover:underline">Get a quote</a> or email <a href="mailto:hello@inletmove.ca" class="text-pacific underline-offset-4 hover:underline">hello@inletmove.ca</a>.
      </p>

      <div class="space-y-8">
        {faqs.map((faq, i) => (
          <div class="border-b border-line-light pb-8 last:border-0">
            <h2 class="mb-3 font-display text-xl font-medium leading-tight tracking-tight text-inlet-navy display-soft">
              {faq.question}
            </h2>
            <p class="font-body text-base leading-relaxed text-charcoal">
              {faq.answer}
            </p>
          </div>
        ))}
      </div>

      <div class="mt-16 rounded-xl border border-line-light bg-bone p-8 text-center">
        <h2 class="mb-3 font-display text-2xl font-medium tracking-tight text-inlet-navy display-soft">
          Still have questions?
        </h2>
        <p class="mb-6 font-body text-base text-graphite">
          We're real humans, based in Vancouver. Get in touch.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a
            href="/quote"
            class="inline-flex items-center gap-2 rounded-md bg-ember px-7 py-3.5 font-body text-base font-semibold text-bone shadow-cta transition-all hover:-translate-y-px hover:bg-ember-warm"
          >
            Get a quote <span aria-hidden>&rarr;</span>
          </a>
          <a
            href="mailto:hello@inletmove.ca"
            class="inline-flex items-center gap-2 rounded-md border border-line-mid bg-paper px-7 py-3.5 font-body text-base font-semibold text-inlet-navy transition hover:bg-bone-warm"
          >
            Email us
          </a>
        </div>
      </div>
    </div>
  </article>

  <Footer slot="footer" />
</Base>
